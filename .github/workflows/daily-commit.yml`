name: Daily Automated Commit

on:
  schedule:
    # Run daily at 10:30 AM UTC
    - cron: '30 10 * * *'
  workflow_dispatch:

jobs:
  daily-update:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3
      
      - name: Set up Git with email 24f2003684@ds.study.iitm.ac.in
        run: |
          git config --global user.email "24f2003684@ds.study.iitm.ac.in"
          git config --global user.name "DevSync Bot"
      
      - name: Update timestamp file
        run: |
          echo "Last updated: $(date -u +'%Y-%m-%d %H:%M:%S UTC')" > .github/workflows/last-update.txt
      
      - name: Commit changes
        run: |
          git add .github/workflows/last-update.txt
          git commit -m "chore: daily automated update [skip ci]" || true
      
      - name: Push changes
        run: |
          git push origin HEAD:main || git push origin HEAD:master || true
